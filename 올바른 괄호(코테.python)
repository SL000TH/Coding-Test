괄호가 바르게 짝지어졌다는 것은 '(' 문자로 열렸으면 반드시 짝지어서 ')' 문자로 닫혀야 한다는 뜻입니다.

def solution(s):
    
    count = 0
    
    for ch in s:
        if ch == "(":
            count +=1
        else:
            count -=1
        if count < 0:
            return False
        
    if count == 0:
        return True
    else:
        return False
